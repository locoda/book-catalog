---
import { getCollection } from 'astro:content';
import '../styles/catalog.css';

interface Props { title?: string }
const { title = '乙觅书阁 · Etherary' } = Astro.props;

const works = await getCollection('works');
const people = await getCollection('people');
const langs = new Set(works.map(w => w.data.orig_lang));
const years = works.flatMap(w => w.data.readings.map(r => parseInt(r.date.slice(0, 4)))).filter(n => !isNaN(n));
const yearRange = years.length ? `${Math.min(...years)}–${Math.max(...years)}` : '';
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="乙觅书阁 — 乙醚的私人编目，为读过的每一本书立一条目。" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;600;700;900&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>
  <header class="site">
    <a href="/" class="brand">乙觅书阁</a>
    <nav class="site-nav">
      <a href="/works/">目录</a>
      <a href="/people/">著者</a>
      <a href="/subjects/">主题</a>
    </nav>
  </header>

  <slot />

  <footer class="site">
    <span class="stats-line"><b>{works.length}</b> works · <b>{langs.size}</b> languages · <b>{people.length}</b> people{yearRange && ` · ${yearRange}`}</span>
    <span>generated from <a href="https://github.com/locoda/book-catalog">locoda/book-catalog</a></span>
    <span>sources: NeoDB · 手工著录</span>
  </footer>
</body>
</html>
