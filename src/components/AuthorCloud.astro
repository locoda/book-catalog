---
/**
 * 主页著者云：桌面 ≥3 部作品，手机 ≥7 部作品。字号按各自 max sqrt 加权。
 */
import { getCollection } from 'astro:content';

const TOP_N = 24;
const THRESH_DESK = 4;
const THRESH_MOB = 7;

const [works, people] = await Promise.all([
  getCollection('works'),
  getCollection('people'),
]);

const counts = new Map<string, number>();
for (const w of works) {
  for (const c of w.data.creators) counts.set(c, (counts.get(c) ?? 0) + 1);
}

const byCount = [...counts].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));

const deskAll = byCount.filter(([, n]) => n >= THRESH_DESK);
const mobAll  = byCount.filter(([, n]) => n >= THRESH_MOB);

if (deskAll.length === 0) return new Response(null, { status: 204 });

const desk = deskAll.slice(0, TOP_N);
const mob  = mobAll;

const size = (n: number, max: number) => (12 + 7 * Math.sqrt(n / max)).toFixed(1);

const deskMax = desk[0]![1];
const mobMax  = mob[0]![1];

const peopleMap = new Map(people.map((p) => [p.id, p.data.name]));

/** 从 people forms 推断原名（native script）。跳过转写/翻译类脚本。 */
function nativeName(person: typeof people[number]['data']): string {
  if (!person.forms?.length) return person.name;
  const TRANSLIT = new Set(['romaji', 'ja-kana']);
  // 过滤转写类，只留真实文字体系的 form
  const real = person.forms.filter((f) => !TRANSLIT.has(f.script) && !f.script.endsWith('-Latn'));
  // 优先：非 en / zh / ko 的 native script（ja / fr / de ...）
  // 但纯片假名 ja form 跳过——那是外来名转写（如 カズオ・イシグロ），非 native
  function isKatakanaOnly(s: string) { return /^[\u30A0-\u30FF・\s]+$/.test(s); }
  const native = real.find((f) => {
    if (f.script === 'en' || f.script === 'zh' || f.script === 'ko') return false;
    if (f.script === 'ja' && isKatakanaOnly(f.value)) return false;
    return true;
  });
  if (native) return native.value;
  // 次选：有 ko 或无 en → 中文/韩文著者用 zh 名
  const hasEn = real.some((f) => f.script === 'en');
  const hasKo = real.some((f) => f.script === 'ko');
  if (!hasEn || hasKo) {
    const zhForm = real.find((f) => f.script === 'zh');
    if (zhForm) return zhForm.value;
  }
  return person.name;
}

const nativeMap = new Map(people.map((p) => [p.id, nativeName(p.data)]));

/** chip 显示名：原名与 authority name 不同时用原名，否则用 authority name */
function displayName(id: string): string {
  const n = nativeMap.get(id)!;
  const a = peopleMap.get(id)!;
  return n !== a ? n : a;
}
---

<section class="cloud wrap">
  <header class="sec-head">
    <small class="mono">PEOPLE</small>
    <h2>著者</h2>
    <span class="sec-meta mono">{people.length} 位著者</span>
  </header>

  <!-- 桌面：≥3 -->
  <div class="subject-cloud show-desk">
    {desk.map(([id, count]) => (
      <a class="subject-chip" href={`/people/${id}/`} style={`font-size:${size(count, deskMax)}px`}>
        {displayName(id)}<span class="mono">{count}</span>
      </a>
    ))}
    <a class="subject-chip subject-more mono" href="/people/">全部著者 →</a>
  </div>

  <!-- 手机：≥7 -->
  <div class="subject-cloud show-mob">
    {mob.map(([id, count]) => (
      <a class="subject-chip" href={`/people/${id}/`} style={`font-size:${size(count, mobMax)}px`}>
        {displayName(id)}<span class="mono">{count}</span>
      </a>
    ))}
    <a class="subject-chip subject-more mono" href="/people/">全部著者 →</a>
  </div>
</section>

<style>
  .show-mob { display: none; }
  @media (max-width: 700px) {
    .show-desk { display: none; }
    .show-mob.sec-meta { display: inline; }
    .subject-cloud.show-mob { display: flex; }
  }
</style>
