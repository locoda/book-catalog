---
/**
 * 2b 语言流向：原语言 → 我读的语言。手写 SVG 桑基，构建时算好布局，零 JS。
 */
import { getCollection } from 'astro:content';
import { langFlows } from '../lib/stats';
import { langLabel, langBucket, BUCKET_LABELS } from '../lib/lang';

const works = await getCollection('works');
const { sources, targets, links, totalWorks } = langFlows(works);

const label = (k: string) => (k === 'other' ? '其他语言' : langLabel(k));

/* ---- 布局 ---- */
const U = 0.72;          // px / 種
const GAP = 10;          // 节点间距
const NW = 10;           // 节点宽
const X0 = 120, X1 = 570; // 左右节点 x
const W = 680, PAD = 40; // 画布窄 → 渲染大

interface Node { key: string; total: number; y0: number; used: number }
const layout = (col: { key: string; total: number }[], h: number, colH: number): Node[] => {
  let y = PAD + (h - 2 * PAD - colH) / 2;
  return col.map((n) => {
    const node = { ...n, y0: y, used: 0 };
    y += n.total * U + GAP;
    return node;
  });
};
const colH = (col: { total: number }[]) =>
  col.reduce((a, n) => a + n.total * U, 0) + (col.length - 1) * GAP;
const H = Math.max(colH(sources), colH(targets)) + 2 * PAD;

const srcNodes = layout(sources, H, colH(sources));
const tgtNodes = layout(targets, H, colH(targets));
const srcIdx = new Map(srcNodes.map((n) => [n.key, n]));
const tgtIdx = new Map(tgtNodes.map((n) => [n.key, n]));

// 流排序：先按 source 列序，再按 target 列序，保证 ribbon 不交叉过甚
const tOrder = new Map(tgtNodes.map((n, i) => [n.key, i]));
const sOrder = new Map(srcNodes.map((n, i) => [n.key, i]));
const ordered = [...links].sort((a, b) =>
  (sOrder.get(a.source)! - sOrder.get(b.source)!) || (tOrder.get(a.target)! - tOrder.get(b.target)!));

// 目标侧偏移需按 target 分组、按 source 列序填充
const byTargetOrder = [...links].sort((a, b) =>
  (tOrder.get(a.target)! - tOrder.get(b.target)!) || (sOrder.get(a.source)! - sOrder.get(b.source)!));
const tOffset = new Map<typeof links[0], number>();
for (const l of byTargetOrder) {
  const t = tgtIdx.get(l.target)!;
  tOffset.set(l, t.y0 + t.used);
  t.used += l.value * U;
}

const XM = (X0 + NW + X1) / 2;
const ribbons = ordered.map((l) => {
  const s = srcIdx.get(l.source)!;
  const sy = s.y0 + s.used;
  s.used += l.value * U;
  const ty = tOffset.get(l)!;
  const h = l.value * U;
  return {
    ...l,
    d: `M${X0 + NW},${sy.toFixed(1)} C${XM},${sy.toFixed(1)} ${XM},${ty.toFixed(1)} ${X1},${ty.toFixed(1)} ` +
       `l0,${h.toFixed(1)} C${XM},${(ty + h).toFixed(1)} ${XM},${(sy + h).toFixed(1)} ${X0 + NW},${(sy + h).toFixed(1)} Z`,
    tip: `${label(l.source)} → ${label(l.target)} · ${l.value} 种${l.native ? '（原文直读）' : ''}`,
  };
});

const nativeTotal = links.filter((l) => l.native).reduce((a, l) => a + l.value, 0);

/* ---- 手機版：垂直桑基（原語言在上 → 我讀的在下）---- */
const M_W = 360;
const M_P = 14;
const M_NH = 22;
const M_G = 4;
const M_RH = 200;

// 原語言按 bucket 聚合：英文 / 日文 / 中文 / 其他（節點匾少不疊）
const mSrcBuckets = new Map<string, number>();
for (const s of sources) {
  const b = langBucket(s.key);
  mSrcBuckets.set(b, (mSrcBuckets.get(b) ?? 0) + s.total);
}
const mSources: { key: string; total: number }[] = ['zh', 'ja', 'en', 'other']
  .filter(b => mSrcBuckets.has(b))
  .map(b => ({ key: b, total: mSrcBuckets.get(b)! }))
  .sort((a, b) => b.total - a.total)
  .sort((a, b) => (a.key === 'other' ? 1 : 0) - (b.key === 'other' ? 1 : 0));

const mLinkMap = new Map<string, { source: string; target: string; value: number; native: boolean }>();
for (const l of links) {
  const src = langBucket(l.source);
  const k = `${src}→${l.target}`;
  const existing = mLinkMap.get(k);
  if (existing) { existing.value += l.value; existing.native = existing.native && l.native; }
  else { mLinkMap.set(k, { source: src, target: l.target, value: l.value, native: l.native }); }
}
const mLinks = [...mLinkMap.values()];

// 按比例分配宽度（非等分）
const mSrcTotalAll = mSources.reduce((a, n) => a + n.total, 0);
const mTgtTotalAll = targets.reduce((a, n) => a + n.total, 0);
const mSrcBand = M_W - 2 * M_P - (mSources.length - 1) * M_G;
const mTgtBand = M_W - 2 * M_P - (targets.length - 1) * M_G;

interface MNode { key: string; total: number; x0: number; w: number; used: number }
const mSrcNodes: MNode[] = [];
const mTgtNodes: MNode[] = [];
{
  let x = M_P;
  for (const n of mSources) {
    const w = (n.total / mSrcTotalAll) * mSrcBand;
    mSrcNodes.push({ ...n, x0: x, w, used: 0 });
    x += w + M_G;
  }
}
{
  let x = M_P;
  for (const n of targets) {
    const w = (n.total / mTgtTotalAll) * mTgtBand;
    mTgtNodes.push({ ...n, x0: x, w, used: 0 });
    x += w + M_G;
  }
}

const mSOrder = new Map(mSrcNodes.map((n, i) => [n.key, i]));
const mTOrder = new Map(mTgtNodes.map((n, i) => [n.key, i]));
const mSMap = new Map(mSrcNodes.map(n => [n.key, n]));
const mTMap = new Map(mTgtNodes.map(n => [n.key, n]));

// 目標側偏移
const mByTgt = [...mLinks].sort((a, b) =>
  (mTOrder.get(a.target)! - mTOrder.get(b.target)!) || (mSOrder.get(a.source)! - mSOrder.get(b.source)!));
const mTOffset = new Map<(typeof mLinks)[0], number>();
for (const l of mByTgt) {
  const t = mTMap.get(l.target)!;
  mTOffset.set(l, t.x0 + t.used);
  t.used += (l.value / t.total) * t.w;
}

const M_TOP = 72;
const M_BOT = M_TOP + M_NH + M_RH;
const M_H = M_BOT + M_NH + 40;
const M_MID = (M_TOP + M_NH + M_BOT) / 2;

mSrcNodes.forEach(n => n.used = 0);

const mLabel = (k: string) => BUCKET_LABELS[k as 'zh'|'ja'|'en'|'other'] ?? label(k);

const mOrdered = [...mLinks].sort((a, b) =>
  (mSOrder.get(a.source)! - mSOrder.get(b.source)!) || (mTOrder.get(a.target)! - mTOrder.get(b.target)!));

const mRibbons = mOrdered.map(l => {
  const s = mSMap.get(l.source)!;
  const sx = s.x0 + s.used;
  const sw = (l.value / s.total) * s.w;
  s.used += sw;
  const tx = mTOffset.get(l)!;
  const t = mTMap.get(l.target)!;
  const tw = (l.value / t.total) * t.w;

  const topY = M_TOP + M_NH;
  const botY = M_BOT;
  return {
    ...l,
    d: `M${sx.toFixed(1)},${topY} C${sx.toFixed(1)},${M_MID} ${tx.toFixed(1)},${M_MID} ${tx.toFixed(1)},${botY} ` +
       `l${tw.toFixed(1)},0 C${(tx + tw).toFixed(1)},${M_MID} ${(sx + sw).toFixed(1)},${M_MID} ${(sx + sw).toFixed(1)},${topY} Z`,
    tip: `${mLabel(l.source)} → ${label(l.target)} · ${l.value} 种${l.native ? '（原文）' : ''}`,
  };
});

---
<section class="langflow wrap">
  <header class="sec-head">
    <small class="mono">LANGUAGE FLOW</small>
    <h2>语言流向</h2>
    <span class="sec-meta mono">{totalWorks} 种</span>
    <span class="flow-legend mono"><i class="lg lg-tr"></i>译本&nbsp;&nbsp;<i class="lg lg-na"></i>原文直读&nbsp;{nativeTotal}&nbsp;种</span>
  </header>
  <div class="flow-desk flow-scroll">
    <svg viewBox={`0 0 ${W} ${Math.ceil(H)}`} role="img" aria-label="原语言到我读的语言的流向图" style={`--h:${Math.ceil(H)}px`}>
      <text class="col-head" x={X0 + NW} y={14} text-anchor="end">原语言&nbsp;ORIG</text>
      <text class="col-head" x={X1} y={14} text-anchor="start">我读的&nbsp;MINE</text>
      {ribbons.map((r) => (
        <path class={`ribbon ${r.native ? 'native' : ''}`} d={r.d}><title>{r.tip}</title></path>
      ))}
      {srcNodes.map((n) => (
        <>
          <rect class="node" x={X0} y={n.y0} width={NW} height={Math.max(n.total * U, 1.5)} />
          <text class="nlabel" x={X0 - 8} y={n.y0 + (n.total * U) / 2 + 4} text-anchor="end">
            {label(n.key)}<tspan class="ncount">&nbsp;{n.total}</tspan>
          </text>
        </>
      ))}
      {tgtNodes.map((n) => (
        <>
          <rect class="node" x={X1} y={n.y0} width={NW} height={Math.max(n.total * U, 1.5)} />
          <text class="nlabel" x={X1 + NW + 8} y={n.y0 + (n.total * U) / 2 + 4} text-anchor="start">
            {label(n.key)}<tspan class="ncount">&nbsp;{n.total}</tspan>
          </text>
        </>
      ))}
    </svg>
  </div>

  <div class="flow-mob">
    <svg viewBox={`0 0 ${M_W} ${Math.ceil(M_H)}`} role="img" aria-label="原语言到我读的语言的垂直流向图">
      <text class="col-head" x={M_W / 2} y={28} text-anchor="middle">原语言 → 我读的 &nbsp;ORIG → MINE</text>
      <!-- 原語言節點（上） -->
      {mSrcNodes.map((n) => (
        <>
          <rect class="node" x={n.x0} y={M_TOP} width={n.w} height={M_NH} rx="2" />
          <text class="mnlabel" x={n.x0 + n.w / 2} y={M_TOP - 18} text-anchor="middle">
            {mLabel(n.key)}
            <tspan class="mncount" x={n.x0 + n.w / 2} dy="13">{n.total}</tspan>
          </text>
        </>
      ))}
      <!-- Ribbons -->
      {mRibbons.map((r) => (
        <path class={`ribbon ${r.native ? 'native' : ''}`} d={r.d}><title>{r.tip}</title></path>
      ))}
      <!-- 我讀的節點（下） -->
      {mTgtNodes.map((n) => (
        <>
          <rect class="node" x={n.x0} y={M_BOT} width={n.w} height={M_NH} rx="2" />
          <text class="mnlabel" x={n.x0 + n.w / 2} y={M_BOT + M_NH + 16} text-anchor="middle">
            {label(n.key)}
            <tspan class="mncount" x={n.x0 + n.w / 2} dy="13">{n.total}</tspan>
          </text>
        </>
      ))}
    </svg>
  </div>
</section>
