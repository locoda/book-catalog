---
/**
 * 2a 阅读时间线：年 × 月热力网格（桌面）+ 年度柱状图（手机）。构建时渲染，零 JS。
 */
import { getCollection } from 'astro:content';
import { readingHeatmap } from '../lib/stats';

const works = await getCollection('works');
const { years, maxMonth, totalReadings } = readingHeatmap(works);

// 平方根色阶：极端峰值（2025）不至于把其他月份压成全黑
const alpha = (n: number) => (n === 0 ? 0 : 0.12 + 0.88 * Math.sqrt(n / maxMonth));
const MONTHS = Array.from({ length: 12 }, (_, i) => i + 1);

// 手机版柱状图：年度总计
const maxYear = Math.max(...years.map(y => y.total));
const barAlpha = (n: number) => (n === 0 ? 0 : 0.18 + 0.82 * Math.sqrt(n / maxYear));
---
<section class="timeline wrap">
  <header class="sec-head">
    <small class="mono">TIMELINE</small>
    <h2>閱讀年表</h2>
    <span class="sec-meta mono">{totalReadings} 筆</span>
  </header>
  <!-- 桌面：月份热力图 -->
  <div class="heat-grid">
    <div class="heat">
      <div class="heat-row heat-head">
        <span class="heat-year"></span>
        {MONTHS.map((m) => <span class="heat-m mono">{m}</span>)}
        <span class="heat-total mono">計</span>
      </div>
      {years.map((y) => (
        <div class="heat-row">
          <span class="heat-year mono">{y.year}</span>
          {y.months.map((n, i) => (
            <span
              class={`heat-cell ${alpha(n) > 0.68 ? 'dark-text' : ''}`}
              style={`--a:${alpha(n).toFixed(3)}`}
              title={`${y.year}-${String(i + 1).padStart(2, '0')} · ${n} 筆`}
            >{n > 0 && <i>{n}</i>}</span>
          ))}
          <span class="heat-total mono">{y.total}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- 手机：年度柱状图 -->
  <div class="heat-bars">
    {years.map((y) => (
      <div class="bar-row">
        <span class="bar-year mono">{y.year}</span>
        <div class="bar-track">
          <div class={`bar-fill ${barAlpha(y.total) > 0.68 ? 'dark-text' : ''}`}
               style={`--w:${(y.total / maxYear * 100).toFixed(1)}%;--a:${barAlpha(y.total).toFixed(3)}`}>
            {y.total > 0 && <span class="bar-val mono">{y.total}</span>}
          </div>
        </div>
      </div>
    ))}
  </div>
</section>
