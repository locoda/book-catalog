---
import Base from '../layouts/Base.astro';
import ReadingTimeline from '../components/ReadingTimeline.astro';
import LangFlow from '../components/LangFlow.astro';
import SubjectCloud from '../components/SubjectCloud.astro';
import AuthorCloud from '../components/AuthorCloud.astro';
---
<Base>
  <section class="portal wrap">
    <p class="portal-intro">
      為讀過的每一本書，立一條目。
    </p>
  </section>

  <ReadingTimeline />
  <LangFlow />
  <SubjectCloud />
  <AuthorCloud />

  <section class="wrap portal-bottom">
    <header class="sec-head">
      <small class="mono">INDEXES</small>
      <h2>检索入口</h2>
    </header>
    <nav class="portal-nav">
      <a href="/works/" class="portal-card">
        <span class="portal-card-title">全部馆藏</span>
        <small>WORKS</small>
      </a>
      <a href="/people/" class="portal-card">
        <span class="portal-card-title">著者索引</span>
        <small>PEOPLE</small>
      </a>
      <a href="/subjects/" class="portal-card">
        <span class="portal-card-title">主题词</span>
        <small>SUBJECTS</small>
      </a>
    </nav>
  </section>
</Base>
