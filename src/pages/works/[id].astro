---
import { getCollection, getEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { langLabel } from '../../lib/lang';
import { editionLabel } from '../../lib/edition';
import { subjectUrl } from '../../lib/subjects';

export async function getStaticPaths() {
  const works = await getCollection('works');
  return works.map((w) => ({ params: { id: w.id }, props: { work: w } }));
}

const { work } = Astro.props;
const d = work.data;

const resolved = await Promise.all(d.creators.map((ref) => getEntry(ref)));
const missing = d.creators.filter((_, i) => !resolved[i]).map((ref) => ref.id);
if (missing.length) {
  throw new Error(`「${work.id}」引用了不存在的 people 记录：${missing.join(', ')}（安全网：悬空引用阻断构建）`);
}
const creators = resolved.filter((p) => p != null);

// 每位著者的馆藏中其他作品
const allWorks = await getCollection('works');
const creatorData = creators.map((p) => ({
  person: p,
  otherWorks: allWorks.filter((w) => w.id !== work.id && w.data.creators.some((c) => c.id === p!.id)),
}));

const mine = d.expressions.find((e) => e.mine);
const displayTitle = mine?.title ?? d.title;
const showOrigSubtitle = d.title !== displayTitle;
const otherTitles = [...new Set(
  d.expressions.map((e) => e.title).filter((t) => t !== displayTitle && t !== d.title)
)].join(' · ');
const firstRead = d.readings[0]?.date?.slice(0, 4);
const lastRead = d.readings[d.readings.length - 1]?.date?.slice(0, 4);
---
<Base title={`${displayTitle} · 乙觅书阁`}>
  <nav class="breadcrumb wrap"><a href="/works/" onclick="history.back();return false">← 返回</a></nav>

  <div class="main wrap">
    <article class="cat-card">
      {d.rating != null && <div class="stamp-badge"><b>{d.rating}</b></div>}
      <div class="callno"><span>{work.id}</span><span>{d.callno}</span></div>
      <h1 class="work-title jp">{displayTitle}</h1>
      {showOrigSubtitle && (
        <p class="work-sub work-orig">
          原题 · <span class="jp">{d.title}</span> <span class="mono">{langLabel(d.orig_lang)}</span>
        </p>
      )}
      {otherTitles && <p class="work-sub">{otherTitles}</p>}
      <div>
        {creators.map((p) => (
          <a class="author-link" href={`/people/${p!.id}/`}>{p!.data.name}<span class="mono">→ p-{p!.id}</span></a>
        ))}
      </div>

      {d.expressions.length > 0 && (
        <table class="expr-table">
          <caption>EXPRESSIONS / 版本</caption>
          <tr><th>语言</th><th>题名</th><th>译者</th><th></th></tr>
          {d.expressions.map((e) => (
            <tr class={e.mine ? 'mine' : ''}>
              <td>{langLabel(e.lang)} <span class="mono">{e.lang}</span></td>
              <td class="jp">{e.title}</td>
              <td>{e.translator ?? (e.lang === d.orig_lang ? '—（原文）' : '')}</td>
              <td>{e.mine && <span class="tag-mine">我读的版本</span>}</td>
            </tr>
          ))}
        </table>
      )}

      {d.subjects.length > 0 && (
        <div class="subjects">
          <span class="facet-label">主题词</span><br />
          {d.subjects.map((s) => <a class="subj" href={subjectUrl(s)}>{s}</a>)}
        </div>
      )}

      {d.readings.length > 0 && (
        <div class="duecard">
          <h4>READING&nbsp;EVENTS&nbsp;/&nbsp;阅读记录</h4>
          {d.readings.map((r) => (
            <div class="due-row">
              <span class="mono">{r.date}</span>
              {(r.edition || r.lang) && <span>{[r.edition && editionLabel(r.edition), r.lang].filter(Boolean).join(' · ')}</span>}
              {r.note && <em>{r.note}</em>}
            </div>
          ))}
        </div>
      )}
    </article>

    <aside class="side">
      {creatorData.map(({ person, otherWorks }) => (
        <>
          <div class="panel">
            <h3>AUTHORITY&nbsp;RECORD</h3>
            <div class="auth-name">{person!.data.name}</div>
            <div class="auth-forms">
              {person!.data.forms.sort((a, b) => a.script.localeCompare(b.script)).map((f) => (
                <div><span class="mono">{f.script}</span><span class="jp">{f.value}</span></div>
              ))}
              <div><span class="mono">id</span><span>p-{person!.id}</span></div>
            </div>
            <div class="auth-count">
              馆藏中著作 <b>{otherWorks.length + 1}</b> 种
              {firstRead && <> · 阅读 <b>{firstRead}{lastRead && lastRead !== firstRead ? `–${lastRead}` : ''}</b></>}
            </div>
          </div>

          {otherWorks.length > 0 && (
            <div class="panel panel-list">
              <h3>同著者其他作品</h3>
              {otherWorks.map((w) => (
                <a href={`/works/${w.id}/`}>
                  <span>{w.data.expressions.find((e) => e.mine)?.title ?? w.data.title}</span>
                  <span class="mono">{w.data.rating != null ? `${w.data.rating} ●` : ''}</span>
                </a>
              ))}
            </div>
          )}
        </>
      ))}
    </aside>
  </div>
</Base>
