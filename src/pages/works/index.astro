---
import { getCollection, getEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { langLabel, langBucket, BUCKET_LABELS, type LangBucket } from '../../lib/lang';

const works = await getCollection('works');

// 每条 work 解析出：著者显示名、我读的语言、切面数据
const rows = await Promise.all(works.map(async (w) => {
  const creators = await Promise.all(w.data.creators.map((id) => getEntry('people', id)));
  const mine = w.data.expressions.find((e) => e.mine);
  const mineTitle = mine?.title ?? w.data.title;
  return {
    id: w.id,
    data: w.data,
    creatorNames: creators.filter(Boolean).map((p) => p!.data.name).join(' · '),
    mineLang: mine?.lang ?? w.data.orig_lang,
    mineTitle,
    translated: mine && mine.lang !== w.data.orig_lang,
    origBucket: langBucket(w.data.orig_lang),
    firstReadYear: w.data.readings[0]?.date?.slice(0, 4) ?? '',
  };
}));
rows.sort((a, b) => (a.data.callno ?? '').localeCompare(b.data.callno ?? ''));

// 原语言：按 Callno 的四分类（中/日/英/其他）合并，避免几十种具体语言把筛选器塞爆
const bucketOrder: LangBucket[] = ['zh', 'ja', 'en', 'other'];
const origBuckets = bucketOrder.filter((b) => rows.some((r) => r.origBucket === b));
// "其他"桶下的具体语言，展开时再选
const otherLangs = [...new Set(rows.filter((r) => r.origBucket === 'other').map((r) => r.data.orig_lang))]
  .sort((a, b) => langLabel(a).localeCompare(langLabel(b), 'zh'));

const mineLangs = [...new Set(rows.map((r) => r.mineLang))].sort();
const subjects = [...new Set(rows.flatMap((r) => r.data.subjects))].sort();
---
<Base title="館藏列表 · 乙醚書目">
  <nav class="breadcrumb wrap"><a href="/" onclick="history.back();return false">← 返回</a></nav>

  <section class="facets wrap">
    <div class="facet-row" data-facet="orig">
      <span class="facet-label">原語言</span>
      <button class="chip on" data-value="">全部</button>
      {origBuckets.map((b) => <button class="chip" data-value={b}>{BUCKET_LABELS[b]}</button>)}
    </div>
    {otherLangs.length > 0 && (
      <div class="facet-row facet-sub hidden" data-facet="orig-sub">
        <span class="facet-label">其他語言</span>
        <button class="chip on" data-value="">不限</button>
        {otherLangs.map((l) => <button class="chip" data-value={l}>{langLabel(l)}</button>)}
      </div>
    )}
    <div class="facet-row" data-facet="mine">
      <span class="facet-label">我讀的是</span>
      <button class="chip on" data-value="">全部</button>
      {mineLangs.map((l) => <button class="chip" data-value={l}>{langLabel(l)}</button>)}
    </div>
    <button class="chip facet-toggle" id="facet-toggle">更多篩選 ▸</button>
    <div class="facet-extra hidden" id="facet-extra">
    <div class="facet-row" data-facet="subject">
      <span class="facet-label">主題</span>
      <select class="facet-select" id="subject-select">
        <option value="">全部</option>
        {subjects.map((s) => <option value={s}>{s}</option>)}
      </select>
    </div>
    <div class="facet-row">
      <span class="facet-label">年份</span>
      <input class="facet-input facet-year" type="text" id="pubyear-input" placeholder="作品年" autocomplete="off" />
      <input class="facet-input facet-year" type="text" id="readyear-input" placeholder="閱讀年" autocomplete="off" />
    </div>
    <div class="facet-row">
      <span class="facet-label">評分</span>
      <input class="facet-input facet-year" type="text" id="rating-input" placeholder="8 / 8- / -8 / 8-10" autocomplete="off" />
    </div>
    <div class="facet-row">
      <span class="facet-label">作者</span>
      <input class="facet-input" type="text" id="author-input" placeholder="输入著者名筛选…" autocomplete="off" />
    </div>
    </div>
  </section>

  <section class="results wrap">
    <div class="sort-row">
      <span class="facet-label">排序</span>
      <button class="chip on" data-sort="callno">索書號</button>
      <button class="chip" data-sort="rating">評分 ↓</button>
      <button class="chip" data-sort="year">年份 ↓</button>
      <button class="chip" data-sort="title">題名 A–Z</button>
    </div>
    <h3 id="result-label">ALL&nbsp;WORKS&nbsp;/&nbsp;全部館藏</h3>
    <div id="rows">
      {rows.map((r) => (
        <a
          class="row"
          href={`/works/${r.id}/`}
          data-origbucket={r.origBucket}
          data-orig={r.data.orig_lang}
          data-mine={r.mineLang}
          data-subjects={r.data.subjects.join('|')}
          data-year={r.data.year ?? ''}
          data-pubyear={r.data.year ?? ''}
          data-readyear={r.firstReadYear}
          data-creators={r.creatorNames}
          data-rating={r.data.rating ?? -1}
          data-title={r.mineTitle}
        >
          <span class="mono">{r.data.callno ?? r.id}</span>
          <span>{r.mineTitle} <span class="byline">· {r.creatorNames}</span></span>
          <span class="langs">
            {r.translated ? `${langLabel(r.data.orig_lang)} → ${langLabel(r.mineLang)}` : `${langLabel(r.data.orig_lang)} 原文`}
          </span>
          <span class="score">{r.data.status === 'reading' ? '在讀' : r.data.rating != null ? `${r.data.rating} ●` : '—'}</span>
        </a>
      ))}
      <div class="empty-note hidden" id="empty">这个切面下暂时没有著录。</div>
    </div>
  </section>

  <script>
    const active: Record<string, string> = { orig: '', origSub: '', mine: '', subject: '', author: '' };
    let pubFrom = 0, pubTo = 0, readFrom = 0, readTo = 0;
    const origSubRow = document.querySelector<HTMLElement>('[data-facet="orig-sub"]');
    let sortMode = 'callno';

    // 通用 range 解析器：支持 X / X- / -X / X-Y
    function parseRange(v: string): [number, number] {
      if (v.startsWith('-')) {
        const n = +v.slice(1);
        return isNaN(n) ? [0, 0] : [0, n];
      }
      const m = v.match(/^(\d+)(?:-(\d+))?$/);
      if (!m) return [0, 0];
      const a = +m[1], b = m[2] !== undefined ? +m[2] : -1;
      if (v.endsWith('-') && b === -1) return [a, 0];
      if (b >= 0) return [Math.min(a, b), Math.max(a, b)];
      return [a, a];
    }
    function inRange(y: number, from: number, to: number): boolean {
      if (!from && !to) return true;
      if (!y && y !== 0) return false;
      return (!from || y >= from) && (!to || y <= to);
    }

    // 更多筛选 toggle
    const facetToggle = document.getElementById('facet-toggle')!;
    const facetExtra = document.getElementById('facet-extra')!;
    facetToggle.addEventListener('click', () => {
      const open = facetExtra.classList.toggle('hidden');
      facetToggle.textContent = open ? '更多篩選 ▸' : '更多篩選 ▾';
      facetToggle.classList.toggle('on', !open);
    });

    document.querySelectorAll<HTMLElement>('.facet-row').forEach((row) => {
      const facet = row.dataset.facet!;
      row.querySelectorAll<HTMLButtonElement>('.chip').forEach((chip) => {
        chip.addEventListener('click', () => {
          if (facet === 'orig') {
            active.orig = chip.dataset.value ?? '';
            active.origSub = '';
            row.querySelectorAll('.chip').forEach((c) => c.classList.remove('on'));
            chip.classList.add('on');
            if (origSubRow) {
              const showSub = active.orig === 'other';
              origSubRow.classList.toggle('hidden', !showSub);
              origSubRow.querySelectorAll('.chip').forEach((c) => c.classList.remove('on'));
              origSubRow.querySelector('.chip')?.classList.add('on'); // 重置为「不限」
            }
          } else if (facet === 'orig-sub') {
            active.origSub = chip.dataset.value ?? '';
            row.querySelectorAll('.chip').forEach((c) => c.classList.remove('on'));
            chip.classList.add('on');
          } else {
            active[facet] = chip.dataset.value ?? '';
            row.querySelectorAll('.chip').forEach((c) => c.classList.remove('on'));
            chip.classList.add('on');
          }
          apply();
        });
      });
    });

    // 主題下拉
    const subjectSelect = document.getElementById('subject-select') as HTMLSelectElement;
    subjectSelect?.addEventListener('change', () => {
      active.subject = subjectSelect.value;
      apply();
    });

    // 評分輸入（復用 parseRange + none 特殊值）
    let ratingFrom = 0, ratingTo = 0, ratingNone = false;
    const ratingInput = document.getElementById('rating-input') as HTMLInputElement;
    ratingInput?.addEventListener('input', () => {
      const v = ratingInput.value.trim();
      if (!v) { ratingFrom = 0; ratingTo = 0; ratingNone = false; }
      else if (v === 'none') { ratingNone = true; }
      else { [ratingFrom, ratingTo] = parseRange(v); ratingNone = false; }
      apply();
    });

    // 作者搜索
    const authorInput = document.getElementById('author-input') as HTMLInputElement;
    authorInput?.addEventListener('input', () => {
      active.author = authorInput.value.trim().toLowerCase();
      apply();
    });

    // 年份输入
    const pubYearInput = document.getElementById('pubyear-input') as HTMLInputElement;
    const readYearInput = document.getElementById('readyear-input') as HTMLInputElement;
    pubYearInput?.addEventListener('input', () => {
      [pubFrom, pubTo] = parseRange(pubYearInput.value.trim());
      apply();
    });
    readYearInput?.addEventListener('input', () => {
      [readFrom, readTo] = parseRange(readYearInput.value.trim());
      apply();
    });

    // 排序 chips
    document.querySelectorAll<HTMLButtonElement>('.sort-row .chip').forEach((chip) => {
      chip.addEventListener('click', () => {
        sortMode = chip.dataset.sort!;
        document.querySelectorAll('.sort-row .chip').forEach((c) => c.classList.remove('on'));
        chip.classList.add('on');
        apply();
      });
    });

    function apply() {
      let shown = 0;
      const rowsEl = document.getElementById('rows')!;
      const allRows = [...rowsEl.querySelectorAll<HTMLElement>('.row')];

      // 先 filter
      const visible: HTMLElement[] = [];
      allRows.forEach((el) => {
        const okOrig = !active.orig
          || (el.dataset.origbucket === active.orig && (active.orig !== 'other' || !active.origSub || el.dataset.orig === active.origSub));
        const okMine = !active.mine || el.dataset.mine === active.mine;
        const okSubj = !active.subject || (el.dataset.subjects ?? '').split('|').includes(active.subject);
        const okAuthor = !active.author || (el.dataset.creators ?? '').toLowerCase().includes(active.author);
        const okPubYear = inRange(parseInt(el.dataset.pubyear ?? '0') || 0, pubFrom, pubTo);
        const okReadYear = inRange(parseInt(el.dataset.readyear ?? '0') || 0, readFrom, readTo);
        const r = parseFloat(el.dataset.rating ?? '-1');
        const okRating = ratingNone ? r < 0 : inRange(r, ratingFrom, ratingTo);
        const ok = okOrig && okMine && okSubj && okPubYear && okReadYear && okRating && okAuthor;
        el.classList.toggle('hidden', !ok);
        if (ok) { shown++; visible.push(el); }
      });

      // 排序
      visible.sort((a, b) => {
        if (sortMode === 'rating') {
          const ra = parseFloat(a.dataset.rating ?? '-1');
          const rb = parseFloat(b.dataset.rating ?? '-1');
          if (ra !== rb) return rb - ra;
          return (a.dataset.title ?? '').localeCompare(b.dataset.title ?? '', 'zh');
        }
        if (sortMode === 'year') {
          const ya = parseInt(a.dataset.year ?? '0') || 0;
          const yb = parseInt(b.dataset.year ?? '0') || 0;
          if (ya !== yb) return yb - ya;
          return (a.dataset.title ?? '').localeCompare(b.dataset.title ?? '', 'zh');
        }
        if (sortMode === 'title') {
          return (a.dataset.title ?? '').localeCompare(b.dataset.title ?? '', 'zh');
        }
        // callno (default)
        return (a.querySelector('.mono')?.textContent ?? '').localeCompare(b.querySelector('.mono')?.textContent ?? '');
      });

      // 重新插入排序后的可见行
      visible.forEach((el) => rowsEl.appendChild(el));

      document.getElementById('empty')!.classList.toggle('hidden', shown > 0);
      const anyFilter = active.orig || active.mine || active.subject || active.author || pubFrom || pubTo || readFrom || readTo || ratingNone || ratingFrom || ratingTo;
      const sortLabel = sortMode === 'callno' ? '' : ` · ${sortMode === 'rating' ? '評分' : sortMode === 'year' ? '年份' : '題名'}`;
      document.getElementById('result-label')!.textContent = anyFilter
        ? `FACET / 切面 — ${shown} 種${sortLabel}`
        : `ALL WORKS / 全部館藏${sortLabel}`;
    }
  </script>
</Base>
